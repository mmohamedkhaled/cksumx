# Doxyfile for cksumx.
# Generate API docs with:  doxygen docs/Doxyfile
# (Any setting not listed here keeps the doxygen default.)

PROJECT_NAME           = "cksumx"
PROJECT_NUMBER         = 1.0.0
PROJECT_BRIEF          = "Streaming cryptographic checksum utility and library"

# Inputs
INPUT                  = ../include ../src ../README.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = ../README.md
FILE_PATTERNS          = *.hpp *.cpp *.md
EXCLUDE_PATTERNS       = */build/*

# Output
OUTPUT_DIRECTORY       = .
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_XML           = NO
HTML_OUTPUT            = html

# Language
OPTIMIZE_OUTPUT_FOR_C  = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = YES

# Source browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
VERBATIM_HEADERS       = YES

# Modern niceties
HTML_DYNAMIC_SECTIONS  = YES
SEARCHENGINE           = YES
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
FULL_PATH_NAMES        = NO
SORT_MEMBER_DOCS       = NO
