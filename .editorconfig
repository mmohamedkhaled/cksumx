root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
max_line_length = 100

[*.{cpp,hpp,h,c,cc,cxx,hxx}]
indent_size = 4

[*.{cmake,CMakeLists.txt}]
indent_size = 4

[Makefile]
indent_style = tab

[*.sh]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.{json}]
indent_size = 2

[Doxyfile]
indent_style = space
indent_size = 1

[*.{md,markdown}]
# Markdown uses trailing two spaces for hard line breaks; keep them.
trim_trailing_whitespace = false
indent_size = 2
max_line_length = off
