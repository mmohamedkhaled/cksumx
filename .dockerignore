# Version control
.git/
.gitignore
.github/

# Build artifacts (anything copied into the image bloats the build context)
build/
cmake-build-*/
out/
release/
debug/
*.o
*.obj
*.a
*.so
*.dylib
*.exe
compile_commands.json

# Documentation / community files not needed to compile
docs/
*.md
LICENSE
CHANGELOG.md

# IDE / OS
.vscode/
.idea/
.cache/
.DS_Store

# Tooling configs
.clang-format
.editorconfig

# Tests are not needed inside the runtime image
tests/
